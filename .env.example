# SOS Academy Platform Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# REQUIRED ENVIRONMENT VARIABLES
# =============================================================================

# MongoDB Connection String (Required)
# For local development:
MONGODB_URI=mongodb://localhost:27017/sos-academy
# For production/cloud:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sos-academy?retryWrites=true&w=majority

# JWT Secret (Required - change this in production!)
JWT_SECRET=your_secure_jwt_secret_key_here

# Session Secret (Required - change this in production!)
SESSION_SECRET=your_secure_session_secret_here

# Resend API Key (Required for email functionality)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# =============================================================================
# OPTIONAL ENVIRONMENT VARIABLES (with defaults)
# =============================================================================

# Server Configuration
NODE_ENV=development
PORT=4200
LOG_LEVEL=info

# JWT Configuration
JWT_EXPIRATION=1d

# CORS Configuration (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Email Configuration
# Make sure this email is verified in your Resend account
EMAIL_FROM=no-reply@shinobi-open-source.academy

# GitHub API (Optional - for GitHub profile fetching)
GITHUB_TOKEN=your_github_token_here

# GitHub Organization Integration (Optional - for auto-inviting users to org)
# Create a fine-grained PAT with "Organization: Members" read/write permission
GITHUB_ORG_NAME=your-github-org-name
GITHUB_ORG_ADMIN_TOKEN=ghp_your_org_admin_token_here

# =============================================================================
# DISCORD BOT (Kunai) CONFIGURATION
# =============================================================================
# See apps/kunai-bot/README.md for full setup instructions.

# Bot token from the Discord Developer Portal > Bot > Token (Required for the bot)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Channel IDs to post daily reminders in (enable Developer Mode in Discord to copy a channel ID)
DISCORD_GENERAL_CHANNEL_ID=your_general_channel_id_here
DISCORD_MENTORS_CHANNEL_ID=your_private_mentors_channel_id_here

# Cron expression + timezone for the daily reminder (defaults to 9am UTC)
REMINDER_CRON=0 9 * * *
TIMEZONE=UTC

# Set to true to log reminders to the console instead of posting to Discord
DRY_RUN=false

# =============================================================================
# ADMIN PANEL CONFIGURATION
# =============================================================================

# Admin Credentials (for admin panel login at http://localhost:3001)
ADMIN_EMAIL=admin@shinobi-open-source.academy
ADMIN_PASSWORD=admin123

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Frontend Port
FRONTEND_PORT=3000

# Backend API URL (used by frontend & admin panel)
# For local development:
NEXT_PUBLIC_API_URL=http://localhost:4200/api
# For production:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api

# Base Server URL (internal backend URL)
BASE_SERVER_URL=http://localhost:4200
